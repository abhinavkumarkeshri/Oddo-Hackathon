# Environment Variables Example

# Database (Neon Postgres)
# Replace with your actual Neon connection string
DATABASE_URL="postgres://user:password@ep-cold-cherry-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# NextAuth
# Generate a secret via: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# SMTP Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-app-password-or-smtp-password"
SMTP_FROM_EMAIL="no-reply@assetflow.app"
SMTP_FROM_NAME="Assets Flow"

# App
NEXT_PUBLIC_APP_NAME="AssetFlow"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
