# ─── Database (Neon Postgres) ─────────────────────────────────────────────────
# Get both from: Neon dashboard → your project → Connection string
# "Pooled" for DATABASE_URL (app queries via pgbouncer)
# "Direct" for DIRECT_URL (Prisma migrations)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth / Auth.js v5 ────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="your-32-char-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── JWT (custom signing, can match AUTH_SECRET) ─────────────────────────────
JWT_SECRET="your-jwt-secret-here"
JWT_EXPIRE="7d"
JWT_COOKIE_EXPIRE="7"

# ─── SMTP Email (Gmail App Password) ─────────────────────────────────────────
# How to get Gmail App Password:
#   Google Account → Security → 2-Step Verification → App passwords
#   Select "Mail" → "Other (custom name)" → Copy the 16-char password
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_EMAIL="you@gmail.com"
SMTP_PASSWORD="your-gmail-app-password"
FROM_EMAIL="you@gmail.com"
FROM_NAME="Assets Flow"

# ─── Cloudinary (asset image uploads) ────────────────────────────────────────
# Get from: cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AssetFlow"
