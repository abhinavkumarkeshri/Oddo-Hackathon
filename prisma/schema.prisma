// AssetFlow — Complete Prisma Schema
// OTP & reset token stored directly on User (no adapter tables needed)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  EMPLOYEE
  DEPT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECH_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditStatus {
  OPEN
  CLOSED
}

enum AuditResult {
  VERIFIED
  MISSING
  DAMAGED
}

// ─── Department ───────────────────────────────────────────────────────────────

model Department {
  id                 String           @id @default(cuid())
  name               String
  parentDepartmentId String?
  headUserId         String?          @unique
  status             DepartmentStatus @default(ACTIVE)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  parentDepartment Department?  @relation("DeptHierarchy", fields: [parentDepartmentId], references: [id])
  subDepartments   Department[] @relation("DeptHierarchy")
  head             User?        @relation("DeptHead", fields: [headUserId], references: [id])
  users            User[]       @relation("DeptMembers")
  assets           Asset[]
  allocations      Allocation[]
  bookings         Booking[]
  auditCycles      AuditCycle[]
}

// ─── Asset Category ───────────────────────────────────────────────────────────

model AssetCategory {
  id               String   @id @default(cuid())
  name             String   @unique
  customFieldsJson Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  assets Asset[]
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  hashedPassword String

  role         UserRole   @default(EMPLOYEE)
  departmentId String?
  status       UserStatus @default(ACTIVE)

  // Email verification (OTP stored hashed)
  otpCode        String?
  otpExpiresAt   DateTime?
  emailVerified  Boolean   @default(false)

  // Password reset (signed token, 30-min expiry)
  resetToken          String?   @unique
  resetTokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  department       Department? @relation("DeptMembers", fields: [departmentId], references: [id])
  headOfDepartment Department? @relation("DeptHead")

  allocations          Allocation[]        @relation("AllocatedTo")
  transfersFrom        TransferRequest[]   @relation("TransferFrom")
  transfersTo          TransferRequest[]   @relation("TransferTo")
  transfersApproved    TransferRequest[]   @relation("TransferApproved")
  bookings             Booking[]
  maintenanceRaised    MaintenanceRequest[] @relation("RaisedBy")
  maintenanceApproved  MaintenanceRequest[] @relation("ApprovedBy")
  auditCyclesCreated   AuditCycle[]
  auditAssignments     AuditAssignment[]
  notifications        Notification[]
  activityLogs         ActivityLog[]

  @@index([email])
  @@index([departmentId])
  @@index([role])
}

// ─── Asset ────────────────────────────────────────────────────────────────────

model Asset {
  id              String         @id @default(cuid())
  name            String
  categoryId      String
  assetTag        String         @unique          // e.g. AF-0001
  serialNumber    String?        @unique
  qrCode          String?        @unique
  acquisitionDate DateTime?
  acquisitionCost Decimal?       @db.Decimal(12, 2)
  condition       AssetCondition @default(GOOD)
  location        String?
  isBookable      Boolean        @default(false)
  photoUrl        String?
  documentUrls    String[]       @default([])
  status          AssetStatus    @default(AVAILABLE)
  departmentId    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  category     AssetCategory @relation(fields: [categoryId], references: [id])
  department   Department?   @relation(fields: [departmentId], references: [id])

  allocations         Allocation[]
  transferRequests    TransferRequest[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditFindings       AuditFinding[]

  @@index([status])
  @@index([categoryId])
  @@index([departmentId])
}

// ─── Allocation ───────────────────────────────────────────────────────────────

model Allocation {
  id                    String           @id @default(cuid())
  assetId               String
  userId                String
  departmentId          String?
  allocatedAt           DateTime         @default(now())
  expectedReturnDate    DateTime?
  returnedAt            DateTime?
  conditionCheckInNotes String?
  status                AllocationStatus @default(ACTIVE)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  asset      Asset       @relation(fields: [assetId], references: [id])
  user       User        @relation("AllocatedTo", fields: [userId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  @@index([assetId])
  @@index([userId])
  @@index([status])
}

// ─── Transfer Request ─────────────────────────────────────────────────────────

model TransferRequest {
  id           String         @id @default(cuid())
  assetId      String
  fromUserId   String
  toUserId     String
  requestedAt  DateTime       @default(now())
  status       TransferStatus @default(REQUESTED)
  approvedById String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  asset      Asset @relation(fields: [assetId], references: [id])
  fromUser   User  @relation("TransferFrom", fields: [fromUserId], references: [id])
  toUser     User  @relation("TransferTo", fields: [toUserId], references: [id])
  approvedBy User? @relation("TransferApproved", fields: [approvedById], references: [id])

  @@index([assetId])
  @@index([status])
}

// ─── Booking ──────────────────────────────────────────────────────────────────

model Booking {
  id              String        @id @default(cuid())
  assetId         String
  requestedById   String
  departmentId    String?
  startTime       DateTime
  endTime         DateTime
  status          BookingStatus @default(UPCOMING)
  reminderSentAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  asset       Asset       @relation(fields: [assetId], references: [id])
  requestedBy User        @relation(fields: [requestedById], references: [id])
  department  Department? @relation(fields: [departmentId], references: [id])

  @@index([assetId])
  @@index([status])
  @@index([startTime, endTime])
}

// ─── Maintenance Request ──────────────────────────────────────────────────────

model MaintenanceRequest {
  id               String            @id @default(cuid())
  assetId          String
  raisedById       String
  issueDescription String
  priority         Priority          @default(MEDIUM)
  photoUrl         String?
  status           MaintenanceStatus @default(PENDING)
  technicianName   String?
  approvedById     String?
  createdAt        DateTime          @default(now())
  resolvedAt       DateTime?
  updatedAt        DateTime          @updatedAt

  asset      Asset @relation(fields: [assetId], references: [id])
  raisedBy   User  @relation("RaisedBy", fields: [raisedById], references: [id])
  approvedBy User? @relation("ApprovedBy", fields: [approvedById], references: [id])

  @@index([assetId])
  @@index([status])
  @@index([priority])
}

// ─── Audit Cycle ──────────────────────────────────────────────────────────────

model AuditCycle {
  id                String      @id @default(cuid())
  name              String
  scopeDepartmentId String?
  scopeLocation     String?
  startDate         DateTime
  endDate           DateTime
  status            AuditStatus @default(OPEN)
  createdById       String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  scopeDepartment Department? @relation(fields: [scopeDepartmentId], references: [id])
  createdBy       User        @relation(fields: [createdById], references: [id])
  assignments     AuditAssignment[]
  findings        AuditFinding[]

  @@index([status])
}

// ─── Audit Assignment ─────────────────────────────────────────────────────────

model AuditAssignment {
  id           String   @id @default(cuid())
  auditCycleId String
  auditorId    String
  assignedAt   DateTime @default(now())

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  auditor    User       @relation(fields: [auditorId], references: [id])

  @@unique([auditCycleId, auditorId])
  @@index([auditorId])
}

// ─── Audit Finding ────────────────────────────────────────────────────────────

model AuditFinding {
  id           String      @id @default(cuid())
  auditCycleId String
  assetId      String
  result       AuditResult
  notes        String?
  recordedAt   DateTime    @default(now())

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  asset      Asset      @relation(fields: [assetId], references: [id])

  @@index([auditCycleId])
  @@index([result])
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id                String   @id @default(cuid())
  userId            String
  type              String   // e.g. ALLOCATION, MAINTENANCE, OVERDUE, AUDIT
  message           String
  relatedEntityType String?  // e.g. "Asset", "Booking"
  relatedEntityId   String?
  isRead            Boolean  @default(false)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

// ─── Activity Log ─────────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  action      String   // e.g. ASSET_CREATED, ALLOCATION_APPROVED
  entityType  String   // e.g. "Asset", "Allocation"
  entityId    String
  detailsJson Json?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
