# ─── Database (Neon Postgres) ─────────────────────────────────────────────────
# Pooled connection (for app queries via Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"
# Direct connection (for migrations via prisma migrate dev)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth / Auth.js v5 ────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="8f4e2b1c7da8e5f2a3c9b6d5e1f0a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9"
NEXTAUTH_URL="http://localhost:3000"

# ─── JWT (custom / API usage) ─────────────────────────────────────────────────
