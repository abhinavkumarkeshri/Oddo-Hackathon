# ─── Database (Neon Postgres) ─────────────────────────────────────────────────
# Get both URLs from your Neon project dashboard → Connection string (pooled + direct)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ─── NextAuth / Auth.js v5 ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32  (or any 32-char random secret)
AUTH_SECRET="your-32-char-random-secret-here"

# The canonical URL of your app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ─── JWT (custom token signing) ──────────────────────────────────────────────
# Can be the same as AUTH_SECRET, or a separate long random string
JWT_SECRET="your-jwt-secret-here"
JWT_EXPIRE="7d"
JWT_COOKIE_EXPIRE="7"

# ─── Resend (primary transactional email) ────────────────────────────────────
# Get from resend.com → API Keys
# If left empty the app will console.log OTP codes in dev instead of sending email
RESEND_API_KEY=""

# The "from" address for all outgoing emails (must be a verified Resend domain)
EMAIL_FROM="AssetFlow <no-reply@yourdomain.com>"

# ─── SMTP Fallback (Gmail or any SMTP provider) ──────────────────────────────
# Used as alternative transport when RESEND_API_KEY is not set
# For Gmail: use an App Password (not your account password)
#   → Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_EMAIL="you@gmail.com"
SMTP_PASSWORD="your-gmail-app-password"
FROM_EMAIL="you@gmail.com"
FROM_NAME="AssetFlow"

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AssetFlow"
